# ═══════════════════════════════════════════════════════════════════════════════
# Милый Дом — Frontend Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!
# ═══════════════════════════════════════════════════════════════════════════════

# ── Backend API ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4001/api

# ── WebSocket (for real-time chat — Phase 1) ─────────────────────────────────
# NEXT_PUBLIC_WS_URL=http://localhost:4001

# ── Stripe (get publishable key from https://dashboard.stripe.com/apikeys) ───
# REQUIRED for card payment form to appear
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── MapBox (get token from https://account.mapbox.com/access-tokens/) ────────
# REQUIRED for the interactive map view on the listings page
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiZXhhbXBsZSIsImEiOiJleGFtcGxlIn0.example

# ── Images ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FALLBACK_IMAGE_URL=/images/listing-1.jpg

# ── Sentry Error Tracking ─────────────────────────────────────────────────────
# Public DSN (exposed to browser — safe to commit)
# NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
# Server-only DSN (keep secret)
# SENTRY_DSN=https://...@o0.ingest.sentry.io/0
# Required for source map uploads in CI
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org
# SENTRY_PROJECT=milyi-dom-frontend
