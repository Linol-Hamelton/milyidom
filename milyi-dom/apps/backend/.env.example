# ═══════════════════════════════════════════════════════════════════════════════
# Милый Дом — Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4001

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/milyi_dom

# ── JWT (REQUIRED in production — min 32 random chars each) ─────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-use-openssl-rand-base64-48
JWT_REFRESH_SECRET=change-me-refresh-use-openssl-rand-base64-48
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS (comma-separated allowed frontend origins) ──────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend URL (used in links inside emails) ────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Stripe Payments ──────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Create webhook at https://dashboard.stripe.com/webhooks, listen to:
#   payment_intent.succeeded, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (Resend — https://resend.com) ───────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_...

# ── Typesense Full-Text Search ───────────────────────────────────────────────
# Defaults work with docker-compose (auto-started). Override for production.
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=milyi-dom-typesense-dev-key

# ── OAuth: Google ────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com/ → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:4001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4001/api/auth/google/callback

# ── OAuth: VK ─────────────────────────────────────────────────────────────────
# Create at https://vk.com/editapp?act=create
# Authorized redirect URI: http://localhost:4001/api/auth/vk/callback
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_CALLBACK_URL=http://localhost:4001/api/auth/vk/callback

# ── Static images (local dev fallback) ───────────────────────────────────────
IMAGES_BASE_URL=http://localhost:4001/images
# IMAGES_ROOT=/absolute/path/to/images  (optional, defaults to ../../images)

# ── Yandex Object Storage (image uploads) ─────────────────────────────────────
# Leave all empty → local disk fallback (dev mode only)
#
# Setup:
#   1. console.cloud.yandex.ru → Object Storage → Создать бакет
#      Name: milyidom-images  |  Access: Публичный  |  Region: ru-central1
#   2. IAM → Сервисные аккаунты → Создать → роль: storage.uploader
#   3. Этот аккаунт → Статические ключи доступа → Создать
#   4. Скопируйте Key ID и Secret в переменные ниже
#
S3_BUCKET=milyidom-images
S3_REGION=ru-central1
S3_ENDPOINT=https://storage.yandexcloud.net
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public URL prefix (virtual-hosted style, no trailing slash):
CDN_BASE_URL=https://milyidom-images.storage.yandexcloud.net

# ── Anthropic AI (Claude API) ─────────────────────────────────────────────────
# Get API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Sentry Error Tracking ─────────────────────────────────────────────────────
# Get DSN from https://sentry.io/settings/<org>/projects/<project>/keys/
# Leave empty to disable Sentry in development
# SENTRY_DSN=https://...@o0.ingest.sentry.io/0
# SENTRY_RELEASE=1.0.0  (optional, defaults to npm_package_version)
