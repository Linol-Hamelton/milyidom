generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_DATABASE_URL")
  extensions = [postgis]
}

enum Role {
  GUEST
  HOST
  ADMIN
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  UNLISTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  REFUNDED
  FAILED
}

enum NotificationType {
  BOOKING_CONFIRMATION
  BOOKING_REMINDER
  MESSAGE
  NEW_REVIEW
  SYSTEM
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  phone            String?        @unique
  password         String         // empty string for OAuth-only accounts
  role             Role           @default(GUEST)
  isVerified       Boolean        @default(false)
  isSuperhost      Boolean        @default(false)
  lastActiveAt     DateTime?
  blockedAt        DateTime?     // Admin block — null = active
  // OAuth providers
  googleId         String?        @unique
  vkId             String?        @unique
  // Stripe Connect (host payouts) — kept for migration compatibility
  stripeConnectId  String?        @unique
  // YooKassa payouts
  yookassaPayoutId String?
  payoutPhone      String?        // Phone for SBP payouts (+7XXXXXXXXXX)
  // Two-factor authentication (TOTP)
  twoFactorSecret  String?
  twoFactorEnabled Boolean        @default(false)
  // Push notifications (Expo token)
  pushToken        String?        @unique
  // Password security: tracks last password change to invalidate old reset tokens
  passwordChangedAt       DateTime?
  // Email notification preferences
  notifEmailBookings      Boolean @default(true)
  notifEmailMessages      Boolean @default(true)
  notifEmailSavedSearches Boolean @default(true)
  notifEmailMarketing     Boolean @default(false)
  profile          Profile?
  listings         Listing[]      @relation("ListingHost")
  bookings         Booking[]      @relation("BookingGuest")
  favorites        Favorite[]
  reviews          Review[]       @relation("ReviewAuthor")
  sentMessages     Message[]      @relation("MessageSender")
  receivedMessages Message[]      @relation("MessageRecipient")
  hostedConversations      Conversation[] @relation("ConversationHost")
  guestConversations       Conversation[] @relation("ConversationGuest")
  notifications    Notification[]
  loyaltyAccount   LoyaltyAccount?
  savedSearches    SavedSearch[]
  disputes         Dispute[]      @relation("UserDisputes")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Profile {
  id                  String   @id @default(cuid())
  firstName           String
  lastName            String
  avatarUrl           String?
  bio                 String?
  languages           String[] @default([])
  verified            Boolean  @default(false)
  responseRate        Float?   @default(1)
  responseTimeMinutes Int?     @default(60)
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
}

model Listing {
  id            String           @id @default(cuid())
  title         String
  slug          String           @unique
  description   String
  summary       String?
  propertyType  String
  hostId        String
  host          User             @relation("ListingHost", fields: [hostId], references: [id])
  guests        Int
  bedrooms      Int
  beds          Int
  bathrooms     Decimal          @db.Decimal(3, 1)
  basePrice     Decimal          @db.Decimal(10, 2)
  cleaningFee   Decimal?         @db.Decimal(10, 2)
  serviceFee    Decimal?         @db.Decimal(10, 2)
  currency      String           @default("RUB")
  status        ListingStatus    @default(PUBLISHED)
  featured      Boolean          @default(false)
  instantBook   Boolean          @default(false)
  checkInFrom   Int?
  checkOutUntil Int?
  minNights     Int?             @default(1)
  maxNights     Int?
  rating        Float?           @default(0)
  reviewCount   Int              @default(0)
  amenities     ListingAmenity[]
  images        PropertyImage[]
  bookings      Booking[]
  favorites     Favorite[]
  reviews       Review[]         @relation("ListingReviews")
  conversations Conversation[]
  addressLine1  String
  addressLine2  String?
  city          String
  state         String?
  country       String
  postalCode    String?
  latitude      Decimal          @db.Decimal(9, 6)
  longitude     Decimal          @db.Decimal(9, 6)
  location      Unsupported("geography(Point,4326)")?
  // iCal integration
  icalToken     String           @unique @default(cuid())
  icalSyncUrls  String[]         @default([])
  blockedDates  BlockedDate[]
  priceOverrides PriceOverride[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status, featured])
  @@index([city])
  @@index([country])
}

model BlockedDate {
  id        String   @id @default(cuid())
  listingId String
  date      DateTime @db.Date
  source    String   @default("manual") // 'manual' | 'ical_sync' | 'booking'
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([listingId, date])
  @@index([listingId, date])
}

model PriceOverride {
  id        String   @id @default(cuid())
  listingId String
  label     String   // e.g. "Новый год", "Выходные"
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  price     Decimal  @db.Decimal(10, 2)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([listingId, startDate, endDate])
}

model Amenity {
  id        Int              @id @default(autoincrement())
  name      String           @unique
  category  String           @default("general")
  icon      String?
  createdAt DateTime         @default(now())
  listings  ListingAmenity[]
}

model ListingAmenity {
  listingId String
  amenityId Int
  listing   Listing @relation(fields: [listingId], references: [id])
  amenity   Amenity @relation(fields: [amenityId], references: [id])

  @@id([listingId, amenityId])
}

model PropertyImage {
  id          String   @id @default(cuid())
  listingId   String
  url         String
  description String?
  position    Int      @default(0)
  isPrimary   Boolean  @default(false)
  listing     Listing  @relation(fields: [listingId], references: [id])
  createdAt   DateTime @default(now())
}

model Booking {
  id         String        @id @default(cuid())
  listingId  String
  guestId    String
  checkIn    DateTime
  checkOut   DateTime
  status     BookingStatus @default(PENDING)
  adults     Int
  children   Int           @default(0)
  infants    Int           @default(0)
  pets       Int           @default(0)
  totalPrice Decimal       @db.Decimal(10, 2)
  currency   String        @default("RUB")
  payment    Payment?
  listing    Listing       @relation(fields: [listingId], references: [id])
  guest      User          @relation("BookingGuest", fields: [guestId], references: [id])
  review     Review?
  disputes   Dispute[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([listingId, checkIn, checkOut], name: "listing_reservation_unique")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model Review {
  id            String   @id @default(cuid())
  rating        Int
  comment       String?
  isPublic      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  listingId     String
  bookingId     String   @unique
  authorId      String
  listing       Listing  @relation("ListingReviews", fields: [listingId], references: [id])
  booking       Booking  @relation(fields: [bookingId], references: [id])
  author        User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  cleanliness   Int
  communication Int
  checkIn       Int
  accuracy      Int
  location      Int
  value         Int
  // Host reply
  hostReply     String?
  hostRepliedAt DateTime?
  // Admin moderation
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Payment {
  id         String        @id @default(cuid())
  bookingId  String        @unique
  providerId String
  status     PaymentStatus @default(PENDING)
  amount     Decimal       @db.Decimal(10, 2)
  currency   String        @default("RUB")
  method     String
  receiptUrl String?
  capturedAt DateTime?
  booking    Booking       @relation(fields: [bookingId], references: [id])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model Conversation {
  id        String    @id @default(cuid())
  listingId String?
  hostId    String
  guestId   String
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  listing   Listing?  @relation(fields: [listingId], references: [id])
  host      User      @relation("ConversationHost", fields: [hostId], references: [id])
  guest     User      @relation("ConversationGuest", fields: [guestId], references: [id])

  @@unique([hostId, guestId, listingId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  recipientId    String
  body           String
  readAt         DateTime?
  sentAt         DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  recipient      User         @relation("MessageRecipient", fields: [recipientId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
}

// ── Audit log ────────────────────────────────────────────────────────────────
// Immutable record of critical security and business events.
// Never delete rows — archive to cold storage after 90 days.
// ── Loyalty programme ────────────────────────────────────────────────────────
enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model LoyaltyAccount {
  id           String               @id @default(cuid())
  userId       String               @unique
  points       Int                  @default(0)   // current redeemable balance
  totalEarned  Int                  @default(0)   // lifetime earned (determines tier)
  tier         LoyaltyTier          @default(BRONZE)
  user         User                 @relation(fields: [userId], references: [id])
  transactions LoyaltyTransaction[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model LoyaltyTransaction {
  id          String         @id @default(cuid())
  accountId   String
  points      Int            // positive = earn, negative = spend/expire
  type        String         // EARN | REDEEM | BONUS | EXPIRE
  description String
  bookingId   String?
  account     LoyaltyAccount @relation(fields: [accountId], references: [id])
  createdAt   DateTime       @default(now())

  @@index([accountId, createdAt])
}

enum AuditAction {
  // Auth
  USER_LOGIN
  USER_LOGOUT
  USER_REGISTER
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_COMPLETE
  PASSWORD_CHANGE
  TOKEN_REFRESH
  // Bookings
  BOOKING_CREATE
  BOOKING_CANCEL
  BOOKING_STATUS_CHANGE
  // Payments
  PAYMENT_INTENT_CREATE
  PAYMENT_SUCCEED
  PAYMENT_FAIL
  // Listings
  LISTING_CREATE
  LISTING_UPDATE
  LISTING_DELETE
  LISTING_PUBLISH
  LISTING_UNPUBLISH
  // Admin
  ADMIN_USER_ROLE_CHANGE
  ADMIN_USER_BLOCK
  ADMIN_BOOKING_OVERRIDE
  ADMIN_LISTING_MODERATE
}

model SavedSearch {
  id              String   @id @default(cuid())
  userId          String
  name            String
  filters         Json
  notifyEmail     Boolean  @default(true)
  lastCheckedAt   DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())

  @@index([email])
}

model AuditLog {
  id           String      @id @default(cuid())
  // Who performed the action (null = unauthenticated)
  userId       String?
  userEmail    String?
  userRole     String?
  // What happened
  action       AuditAction
  // On what resource
  resourceType String?
  resourceId   String?
  // Request context
  ipAddress    String?
  userAgent    String?
  // Additional data (non-PII)
  metadata     Json?
  // Outcome
  success      Boolean     @default(true)
  errorMessage String?
  // When
  createdAt    DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resourceType, resourceId])
}

// ── Disputes ──────────────────────────────────────────────────────────────────
enum DisputeStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

model Dispute {
  id          String        @id @default(cuid())
  bookingId   String
  reporterId  String
  status      DisputeStatus @default(OPEN)
  subject     String
  description String
  adminNotes  String?
  resolvedAt  DateTime?
  booking     Booking       @relation(fields: [bookingId], references: [id])
  reporter    User          @relation("UserDisputes", fields: [reporterId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([bookingId])
  @@index([reporterId])
}
